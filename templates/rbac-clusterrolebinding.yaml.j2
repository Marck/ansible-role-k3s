---
apiVersion: rbac.authorization.k8s.io/v1
kind: ClusterRoleBinding
metadata:
  name: {{ rbac_user.name }}-binding
subjects:
  - kind: User
    name: {{ rbac_user.name }}
    apiGroup: rbac.authorization.k8s.io
roleRef:
  kind: ClusterRole
  name: {{ rbac_user.cluster_role }}
  apiGroup: rbac.authorization.k8s.io
